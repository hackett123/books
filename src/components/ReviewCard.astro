---
import StarRating from "./StarRating.astro";
import BookCover from "./BookCover.astro";

interface Props {
  href: string;
  title: string;
  author: string;
  rating: number;
  cover?: string;
  dateRead?: Date;
  excerpt?: string;
}
const { href, title, author, rating, cover, dateRead, excerpt } =
  Astro.props;

const dateLabel = dateRead
  ? dateRead.toLocaleDateString("en-US", { year: "numeric", month: "long" })
  : undefined;
---

<article class="card">
  <a class="card__cover" href={href} aria-hidden="true" tabindex="-1">
    <BookCover cover={cover} title={title} author={author} width={84} />
  </a>
  <div class="card__body">
    <h2 class="card__title">
      <a href={href}>{title}</a>
    </h2>
    <p class="card__author">by {author}</p>
    <div class="card__meta">
      <StarRating rating={rating} />
      {dateLabel && <span class="meta">· Read {dateLabel}</span>}
    </div>
    {excerpt && <p class="card__excerpt">{excerpt}</p>}
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-5);
    padding-block: var(--space-5);
    border-bottom: var(--hairline);
  }
  .card__cover {
    align-self: start;
  }
  .card__title {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-1);
  }
  .card__title a {
    color: var(--color-ink);
  }
  .card__title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .card__author {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-3);
  }
  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }
  .card__excerpt {
    margin: 0;
    color: var(--color-ink);
    line-height: var(--leading-normal);
  }
  @media (max-width: 32rem) {
    .card {
      gap: var(--space-4);
    }
  }
</style>
