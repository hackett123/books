---
import StarRating from "./StarRating.astro";
import BookCover from "./BookCover.astro";

// A banded reading timeline. The `axis` person's reads run down the central
// column; each `flank` (other readers) sits left/right and appears when the
// "show" toggle is on. A "✓ both read it" badge marks a flank book that the
// axis person also read. Used by /timeline (you on the axis, friends flanking)
// and /timeline/[slug] (a friend on the axis, you flanking).

export interface TimelineAxisEntry {
  title: string;
  author: string;
  cover?: string;
  rating: number;
  href: string;
  external: boolean; // true = link opens out (Goodreads), so target=_blank
  dateRead: Date | null;
}
export interface TimelineFlankBook {
  title: string;
  author: string;
  cover?: string;
  url?: string;
  dateRead: Date | null;
}
export interface TimelineFlank {
  name: string;
  color: string;
  side: "left" | "right";
  href?: string; // legend link (e.g. that reader's page)
  books: TimelineFlankBook[];
}

interface Props {
  axis: TimelineAxisEntry[];
  flanks?: TimelineFlank[];
  toggleLabel?: string;
  bothLabel?: string;
}

const {
  axis,
  flanks = [],
  toggleLabel = "Show friends' timelines",
  bothLabel = "you both read it",
} = Astro.props;

// Match a flank book against the axis person's reads (dated or not) by
// normalized title + author. Strips series suffixes like "(Hierarchy, #1)".
function matchKey(title: string, author: string): string {
  const t = title.toLowerCase().replace(/\(.*?\)/g, "").replace(/[^a-z0-9]+/g, " ").trim();
  const a = (author ?? "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
  return `${t}|${a}`;
}
const axisKeys = new Set(axis.map((e) => matchKey(e.title, e.author)));

const MONTHS = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];
const DOW = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

function keyOf(d: Date | null): string {
  return d
    ? `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, "0")}`
    : "undated";
}
function dayOf(d: Date | null): string {
  return d ? String(d.getUTCDate()) : "";
}
function dowOf(d: Date | null): string {
  return d ? DOW[d.getUTCDay()] : "";
}

interface FlankEntry {
  name: string;
  color: string;
  side: string;
  book: TimelineFlankBook;
}
interface Bucket {
  key: string;
  year: number | null;
  monthIndex: number | null;
  label: string;
  owner: TimelineAxisEntry[];
  left: FlankEntry[];
  right: FlankEntry[];
  hasOwner: boolean;
}

const buckets = new Map<string, Bucket>();
function bucket(d: Date | null): Bucket {
  const key = keyOf(d);
  let b = buckets.get(key);
  if (!b) {
    b = {
      key,
      year: d ? d.getUTCFullYear() : null,
      monthIndex: d ? d.getUTCMonth() : null,
      label: d ? MONTHS[d.getUTCMonth()] : "Undated",
      owner: [],
      left: [],
      right: [],
      hasOwner: false,
    };
    buckets.set(key, b);
  }
  return b;
}

// The timeline only shows dated reads — undated books (axis and flanks') are
// skipped entirely rather than bucketed into an "Undated" section.
for (const e of axis) {
  if (!e.dateRead) continue;
  const b = bucket(e.dateRead);
  b.owner.push(e);
  b.hasOwner = true;
}
for (const f of flanks) {
  for (const book of f.books) {
    if (!book.dateRead) continue;
    const b = bucket(book.dateRead);
    const entry = { name: f.name, color: f.color, side: f.side, book };
    (f.side === "left" ? b.left : b.right).push(entry);
  }
}

const ordered = [...buckets.values()].sort((a, b) => {
  if (a.year === null) return 1;
  if (b.year === null) return -1;
  if (a.year !== b.year) return b.year - a.year;
  return (b.monthIndex ?? 0) - (a.monthIndex ?? 0);
});

interface YearSection {
  label: string;
  months: Bucket[];
}
const yearSections: YearSection[] = [];
for (const b of ordered) {
  const label = b.year === null ? "Undated" : String(b.year);
  let sec = yearSections.find((s) => s.label === label);
  if (!sec) {
    sec = { label, months: [] };
    yearSections.push(sec);
  }
  sec.months.push(b);
}
---

{
  flanks.length > 0 && (
    <div class="tl-controls measure">
      <label class="tl-toggle">
        <input type="checkbox" id="show-friends" />
        <span>{toggleLabel}</span>
      </label>
      <ul class="tl-legend">
        {flanks.map((f) => (
          <li>
            <span class="tl-legend__dot" style={`background:${f.color}`} />
            {f.href ? (
              <a href={f.href} style={`color:${f.color}`}>
                {f.name}
              </a>
            ) : (
              <span style={`color:${f.color}`}>{f.name}</span>
            )}
          </li>
        ))}
        <li class="tl-legend__hint">
          <span class="tl-legend__both">✓</span> {bothLabel}
        </li>
      </ul>
    </div>
  )
}

<div class="timeline" id="timeline">
  {
    yearSections.map((sec) => (
      <section class="tl-year">
        <h2 class="tl-year__label">{sec.label}</h2>
        {sec.months.map((month) => (
          <section
            class:list={["tl-month", { "tl-month--friends-only": !month.hasOwner }]}
            id={month.key}
          >
            <div class="tl-month__label">
              <span>{month.label}</span>
            </div>

            <div class="tl-row">
              {/* left flank */}
              <div class="tl-side tl-side--left">
                {month.left.map(({ name, color, book }) => {
                  const shared = axisKeys.has(matchKey(book.title, book.author));
                  return (
                    <a
                      class:list={["tl-fcard", { "tl-fcard--shared": shared }]}
                      style={`--fc:${color}`}
                      href={book.url ?? "#"}
                      rel="nofollow noopener"
                      target="_blank"
                    >
                      <span class="tl-fcard__cover">
                        <BookCover cover={book.cover} title={book.title} author={book.author} width={34} />
                        {shared && <span class="tl-fcard__both" title="Both read this">✓</span>}
                      </span>
                      <span class="tl-fcard__txt">
                        <span class="tl-fcard__title">{book.title}</span>
                        <span class="tl-fcard__who">{name}</span>
                      </span>
                    </a>
                  );
                })}
              </div>

              {/* central axis */}
              <ol class="tl-mine">
                {month.owner.map((e) => {
                  const linkAttrs = e.external
                    ? { rel: "nofollow noopener", target: "_blank" }
                    : {};
                  return (
                    <li class="tl-item">
                      <span class="tl-item__date">
                        <span class="tl-item__dow">{dowOf(e.dateRead)}</span>
                        <span class="tl-item__day">{dayOf(e.dateRead)}</span>
                      </span>
                      <span class="tl-item__dot" aria-hidden="true" />
                      <a href={e.href} class="tl-item__cover" {...linkAttrs}>
                        <BookCover cover={e.cover} title={e.title} author={e.author} width={44} />
                      </a>
                      <span class="tl-item__body">
                        <a href={e.href} class="tl-item__title" {...linkAttrs}>
                          {e.title}
                          {e.external && <span class="tl-item__ext" title="Rated, not reviewed"> ↗</span>}
                        </a>
                        <span class="tl-item__author">{e.author}</span>
                      </span>
                      {e.rating > 0 && <StarRating rating={e.rating} size="0.8rem" />}
                    </li>
                  );
                })}
              </ol>

              {/* right flank */}
              <div class="tl-side tl-side--right">
                {month.right.map(({ name, color, book }) => {
                  const shared = axisKeys.has(matchKey(book.title, book.author));
                  return (
                    <a
                      class:list={["tl-fcard", { "tl-fcard--shared": shared }]}
                      style={`--fc:${color}`}
                      href={book.url ?? "#"}
                      rel="nofollow noopener"
                      target="_blank"
                    >
                      <span class="tl-fcard__cover">
                        <BookCover cover={book.cover} title={book.title} author={book.author} width={34} />
                        {shared && <span class="tl-fcard__both" title="Both read this">✓</span>}
                      </span>
                      <span class="tl-fcard__txt">
                        <span class="tl-fcard__title">{book.title}</span>
                        <span class="tl-fcard__who">{name}</span>
                      </span>
                    </a>
                  );
                })}
              </div>
            </div>
          </section>
        ))}
      </section>
    ))
  }
</div>

<script>
  const cb = document.getElementById("show-friends") as HTMLInputElement | null;
  const tl = document.getElementById("timeline");
  cb?.addEventListener("change", () => {
    tl?.classList.toggle("show-friends", cb.checked);
  });
</script>

<style>
  .tl-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-5);
    margin-top: var(--space-5);
    padding: var(--space-3) 0;
    border-top: var(--hairline);
    border-bottom: var(--hairline);
  }
  .tl-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
  }
  .tl-toggle input {
    accent-color: var(--color-accent);
    width: 1rem;
    height: 1rem;
  }
  .tl-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tl-legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: var(--text-sm);
  }
  .tl-legend__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .tl-legend a:hover {
    text-decoration: underline;
  }
  .tl-legend__hint {
    color: var(--color-muted);
  }
  .tl-legend__both {
    display: inline-grid;
    place-items: center;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: 9px;
  }

  .timeline {
    margin-top: var(--space-6);
  }
  .tl-year {
    margin-bottom: var(--space-6);
  }
  .tl-year__label {
    font-size: var(--text-2xl);
    color: var(--color-night);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  /* A month band. The central column (axis reads) is the spine; flanks sit
     left/right and only take space when the toggle is on. */
  .tl-month {
    --axis: 33rem; /* width of the central reading column */
    --flank: 0px; /* flank width — expands when the toggle is on */
    display: grid;
    grid-template-columns: var(--flank) minmax(0, var(--axis)) var(--flank);
    justify-content: center;
    gap: var(--space-4);
    scroll-margin-top: 5rem;
  }
  .timeline.show-friends .tl-month {
    --flank: 12rem;
  }
  .tl-month--friends-only {
    display: none;
  }
  .timeline.show-friends .tl-month--friends-only {
    display: grid;
  }

  /* Centered month label sitting on the axis, with a hairline through it. */
  .tl-month__label {
    grid-column: 1 / -1;
    text-align: center;
    position: relative;
    margin-bottom: var(--space-2);
  }
  .tl-month__label::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    border-top: var(--hairline);
  }
  .tl-month__label span {
    position: relative;
    background: var(--color-bg);
    padding: 0 var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-muted);
  }
  .tl-month:target .tl-month__label span {
    color: var(--color-accent);
  }
  .tl-month:target {
    animation: tl-flash 1.2s ease;
  }
  @keyframes tl-flash {
    from { background: var(--color-accent-soft); }
    to { background: transparent; }
  }

  .tl-row {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: subgrid;
  }

  /* Flanks */
  .tl-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-3);
  }
  .tl-side--left {
    align-items: flex-end;
  }
  /* Hidden until the toggle is on (also keeps them out of tab order visually). */
  .tl-side .tl-fcard {
    display: none;
  }
  .timeline.show-friends .tl-side .tl-fcard {
    display: flex;
  }
  .tl-fcard {
    align-items: center;
    gap: var(--space-2);
    max-width: 100%;
    color: var(--color-ink);
    border-left: 2px solid transparent;
  }
  .tl-fcard:hover {
    text-decoration: none;
  }
  .tl-fcard:hover .tl-fcard__title {
    color: var(--fc);
  }
  .tl-side--left .tl-fcard {
    flex-direction: row-reverse;
    text-align: right;
    border-left: none;
    border-right: 2px solid var(--fc);
    padding-right: var(--space-2);
  }
  .tl-side--right .tl-fcard {
    border-left: 2px solid var(--fc);
    padding-left: var(--space-2);
  }
  .tl-fcard__txt {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .tl-fcard__title {
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
    font-weight: var(--weight-medium);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .tl-fcard__who {
    font-size: 0.68rem;
    color: var(--fc);
  }
  .tl-fcard__cover {
    position: relative;
    flex: none;
    display: block;
  }
  /* "Both read this" check badge on the cover corner. */
  .tl-fcard__both {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 15px;
    height: 15px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: 9px;
    line-height: 1;
    box-shadow: 0 0 0 2px var(--color-bg);
  }
  .tl-side--left .tl-fcard__both {
    right: auto;
    left: -5px;
  }
  /* Shared books read a touch stronger. */
  .tl-fcard--shared .tl-fcard__title {
    color: var(--color-ink);
    font-weight: var(--weight-bold);
  }

  /* The central axis */
  .tl-mine {
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .tl-item {
    display: grid;
    grid-template-columns: 3.4em 14px 44px 1fr auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: var(--hairline);
  }
  /* A small calendar chip: weekday over day-of-month, so the number reads as
     a date rather than a bare count. */
  .tl-item__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }
  .tl-item__dow {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .tl-item__day {
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
  }
  .tl-item__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    justify-self: center;
  }
  .tl-item__cover {
    display: block;
  }
  .tl-item__body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .tl-item__title {
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    line-height: var(--leading-snug);
  }
  .tl-item__title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .tl-item__ext {
    color: var(--color-muted);
    font-size: 0.8em;
  }
  .tl-item__author {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* Narrow screens: drop the flanks below the month, single column. */
  @media (max-width: 52rem) {
    .tl-month {
      --flank: 0px !important;
      grid-template-columns: minmax(0, 1fr);
    }
    .tl-row {
      grid-template-columns: minmax(0, 1fr);
    }
    .tl-side {
      align-items: stretch;
    }
    .timeline.show-friends .tl-side .tl-fcard {
      display: flex;
    }
    .tl-side--left .tl-fcard,
    .tl-side--right .tl-fcard {
      flex-direction: row;
      text-align: left;
      border-right: none;
      border-left: 2px solid var(--fc);
      padding-left: var(--space-2);
      padding-right: 0;
    }
  }
  @media (max-width: 32rem) {
    .tl-item {
      grid-template-columns: 3em 10px 36px 1fr;
    }
    .tl-item :global(.stars) {
      display: none;
    }
  }
</style>
