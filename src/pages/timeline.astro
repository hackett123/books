---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline, { type TimelineFlank } from "../components/Timeline.astro";
import { getReadBooks } from "../lib/library";
import { getFriends } from "../lib/friends";
import { withBase } from "../lib/url";

const axis = await getReadBooks();
const friends = getFriends();

// A color + a side (friends flank the central axis) for each friend.
const PALETTE = ["#2f7e7e", "#7a5bb0", "#b0662f", "#3f7d44", "#a23b5e"];
const flanks: TimelineFlank[] = friends.map((f, i) => ({
  name: f.name,
  color: PALETTE[i % PALETTE.length],
  side: i % 2 === 0 ? "right" : "left", // alternate sides of the axis
  href: withBase(`/friends/${f.slug}`),
  books: f.read,
}));
---

<BaseLayout title="Timeline" description="Everything I've read, in order.">
  <section class="measure">
    <p class="eyebrow">In order</p>
    <h1>Reading Timeline</h1>
    <p class="intro__lede">
      Every book, pinned to when I finished it. Newest first.
    </p>
  </section>

  <Timeline axis={axis} flanks={flanks} toggleLabel="Show friends' timelines" />
</BaseLayout>

<style>
  .intro__lede {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 34rem;
  }
</style>
