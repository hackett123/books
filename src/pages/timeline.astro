---
import BaseLayout from "../layouts/BaseLayout.astro";
import StarRating from "../components/StarRating.astro";
import BookCover from "../components/BookCover.astro";
import { getTimeline } from "../lib/library";

const groups = await getTimeline();

function monthDay(d: Date | null): string {
  if (!d) return "";
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<BaseLayout
  title="Timeline"
  description="Everything I've read, in order."
>
  <section class="measure">
    <p class="eyebrow">In order</p>
    <h1>Reading Timeline</h1>
    <p class="intro__lede">
      Every book, pinned to when I finished it. Newest first.
    </p>
  </section>

  <div class="timeline measure">
    {
      groups.map((group) => (
        <section class="tl-year">
          <h2 class="tl-year__label">{group.label}</h2>
          <ol class="tl-list">
            {group.entries.map((e) => {
              const linkAttrs = e.external
                ? { rel: "nofollow noopener", target: "_blank" }
                : {};
              return (
                <li class="tl-item">
                  <span class="tl-item__date">{monthDay(e.dateRead)}</span>
                  <span class="tl-item__dot" aria-hidden="true" />
                  <a href={e.href} class="tl-item__cover" {...linkAttrs}>
                    <BookCover cover={e.cover} title={e.title} author={e.author} width={44} />
                  </a>
                  <span class="tl-item__body">
                    <a href={e.href} class="tl-item__title" {...linkAttrs}>
                      {e.title}
                      {e.external && <span class="tl-item__ext" title="Rated, not reviewed"> ↗</span>}
                    </a>
                    <span class="tl-item__author">{e.author}</span>
                  </span>
                  {e.rating > 0 && <StarRating rating={e.rating} size="0.8rem" />}
                </li>
              );
            })}
          </ol>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .timeline {
    margin-top: var(--space-6);
  }
  .tl-year {
    margin-bottom: var(--space-6);
  }
  .tl-year__label {
    font-size: var(--text-2xl);
    color: var(--color-night);
    margin-bottom: var(--space-3);
  }
  .tl-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tl-item {
    display: grid;
    grid-template-columns: 3.2em 14px 44px 1fr auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: var(--hairline);
  }
  .tl-item__date {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .tl-item__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    justify-self: center;
  }
  .tl-item__cover {
    display: block;
  }
  .tl-item__body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .tl-item__title {
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    line-height: var(--leading-snug);
  }
  .tl-item__title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .tl-item__ext {
    color: var(--color-muted);
    font-size: 0.8em;
  }
  .tl-item__author {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  @media (max-width: 32rem) {
    .tl-item {
      grid-template-columns: 2.8em 10px 36px 1fr;
    }
    .tl-item :global(.stars) {
      display: none;
    }
  }
</style>
