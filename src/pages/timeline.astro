---
import BaseLayout from "../layouts/BaseLayout.astro";
import StarRating from "../components/StarRating.astro";
import BookCover from "../components/BookCover.astro";
import { getReadBooks, type ReadEntry } from "../lib/library";
import { getFriends, type FriendBook } from "../lib/friends";
import { withBase } from "../lib/url";

const ownerBooks = await getReadBooks();
const friends = getFriends();

// A color per friend for their timeline rows + legend.
const PALETTE = ["#2f7e7e", "#7a5bb0", "#b0662f", "#3f7d44", "#a23b5e"];
const friendMeta = friends.map((f, i) => ({
  slug: f.slug,
  name: f.name,
  color: PALETTE[i % PALETTE.length],
}));

const MONTHS = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];

function keyOf(d: Date | null): string {
  return d
    ? `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, "0")}`
    : "undated";
}

interface Bucket {
  key: string;
  year: number | null; // null = undated
  monthIndex: number | null;
  label: string;
  owner: ReadEntry[];
  friends: { slug: string; name: string; color: string; book: FriendBook }[];
  hasOwner: boolean;
}

const buckets = new Map<string, Bucket>();
function bucket(d: Date | null): Bucket {
  const key = keyOf(d);
  let b = buckets.get(key);
  if (!b) {
    b = {
      key,
      year: d ? d.getUTCFullYear() : null,
      monthIndex: d ? d.getUTCMonth() : null,
      label: d ? MONTHS[d.getUTCMonth()] : "Undated",
      owner: [],
      friends: [],
      hasOwner: false,
    };
    buckets.set(key, b);
  }
  return b;
}

for (const e of ownerBooks) {
  const b = bucket(e.dateRead);
  b.owner.push(e);
  b.hasOwner = true;
}
for (const meta of friendMeta) {
  const friend = friends.find((f) => f.slug === meta.slug)!;
  for (const book of friend.read) {
    bucket(book.dateRead).friends.push({ ...meta, book });
  }
}

// Sort buckets newest-first; undated last. Then group into year sections.
const ordered = [...buckets.values()].sort((a, b) => {
  if (a.year === null) return 1;
  if (b.year === null) return -1;
  if (a.year !== b.year) return b.year - a.year;
  return (b.monthIndex ?? 0) - (a.monthIndex ?? 0);
});

interface YearSection {
  label: string;
  months: Bucket[];
}
const yearSections: YearSection[] = [];
for (const b of ordered) {
  const label = b.year === null ? "Undated" : String(b.year);
  let sec = yearSections.find((s) => s.label === label);
  if (!sec) {
    sec = { label, months: [] };
    yearSections.push(sec);
  }
  sec.months.push(b);
}

function dayOf(d: Date | null): string {
  return d ? String(d.getUTCDate()) : "";
}
---

<BaseLayout title="Timeline" description="Everything I've read, in order.">
  <section class="measure">
    <p class="eyebrow">In order</p>
    <h1>Reading Timeline</h1>
    <p class="intro__lede">
      Every book, pinned to when I finished it. Newest first.
    </p>

    {
      friendMeta.length > 0 && (
        <div class="tl-controls">
          <label class="tl-toggle">
            <input type="checkbox" id="show-friends" />
            <span>Show friends' timelines</span>
          </label>
          <ul class="tl-legend">
            {friendMeta.map((m) => (
              <li>
                <span class="tl-legend__dot" style={`background:${m.color}`} />
                <a href={withBase(`/friends/${m.slug}`)} style={`color:${m.color}`}>{m.name}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>

  <div class="timeline measure" id="timeline">
    {
      yearSections.map((sec) => (
        <section class="tl-year">
          <h2 class="tl-year__label">{sec.label}</h2>
          {sec.months.map((month) => (
            <section
              class:list={["tl-month", { "tl-month--friends-only": !month.hasOwner }]}
              id={month.key}
            >
              <h3 class="tl-month__label">{month.label}</h3>
              <ol class="tl-list">
                {month.owner.map((e) => {
                  const linkAttrs = e.external
                    ? { rel: "nofollow noopener", target: "_blank" }
                    : {};
                  return (
                    <li class="tl-item">
                      <span class="tl-item__date">{dayOf(e.dateRead)}</span>
                      <span class="tl-item__dot" aria-hidden="true" />
                      <a href={e.href} class="tl-item__cover" {...linkAttrs}>
                        <BookCover cover={e.cover} title={e.title} author={e.author} width={44} />
                      </a>
                      <span class="tl-item__body">
                        <a href={e.href} class="tl-item__title" {...linkAttrs}>
                          {e.title}
                          {e.external && <span class="tl-item__ext" title="Rated, not reviewed"> ↗</span>}
                        </a>
                        <span class="tl-item__author">{e.author}</span>
                      </span>
                      {e.rating > 0 && <StarRating rating={e.rating} size="0.8rem" />}
                    </li>
                  );
                })}

                {month.friends.map(({ name, color, book }) => (
                  <li class="tl-item tl-item--friend" style={`--fdot:${color}`}>
                    <span class="tl-item__date">{dayOf(book.dateRead)}</span>
                    <span class="tl-item__dot" aria-hidden="true" />
                    <a href={book.url ?? "#"} class="tl-item__cover" rel="nofollow noopener" target="_blank">
                      <BookCover cover={book.cover} title={book.title} author={book.author} width={44} />
                    </a>
                    <span class="tl-item__body">
                      <a href={book.url ?? "#"} class="tl-item__title" rel="nofollow noopener" target="_blank">
                        {book.title}
                      </a>
                      <span class="tl-item__author">
                        {book.author} · <span class="tl-item__who" style={`color:${color}`}>{name}</span>
                      </span>
                    </span>
                    {book.rating > 0 && <StarRating rating={book.rating} size="0.8rem" />}
                  </li>
                ))}
              </ol>
            </section>
          ))}
        </section>
      ))
    }
  </div>
</BaseLayout>

<script>
  const cb = document.getElementById("show-friends") as HTMLInputElement | null;
  const tl = document.getElementById("timeline");
  cb?.addEventListener("change", () => {
    tl?.classList.toggle("show-friends", cb.checked);
  });
</script>

<style>
  .intro__lede {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 34rem;
  }
  .tl-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-5);
    margin-top: var(--space-5);
    padding: var(--space-3) 0;
    border-top: var(--hairline);
    border-bottom: var(--hairline);
  }
  .tl-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
  }
  .tl-toggle input {
    accent-color: var(--color-accent);
    width: 1rem;
    height: 1rem;
  }
  .tl-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tl-legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: var(--text-sm);
  }
  .tl-legend__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .tl-legend a:hover {
    text-decoration: underline;
  }

  .timeline {
    margin-top: var(--space-6);
  }
  .tl-year {
    margin-bottom: var(--space-6);
  }
  .tl-year__label {
    font-size: var(--text-2xl);
    color: var(--color-night);
    margin-bottom: var(--space-3);
  }
  .tl-month {
    display: grid;
    grid-template-columns: 6.5em 1fr;
    gap: var(--space-4);
    scroll-margin-top: 5rem;
  }
  /* Friend-only months stay hidden until the toggle is on. */
  .tl-month--friends-only {
    display: none;
  }
  .timeline.show-friends .tl-month--friends-only {
    display: grid;
  }
  .tl-month__label {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-muted);
    margin: 0;
    padding-top: var(--space-3);
    position: sticky;
    top: 4.5rem;
    align-self: start;
    height: max-content;
  }
  .tl-month:target .tl-month__label {
    color: var(--color-accent);
  }
  .tl-month:target {
    animation: tl-flash 1.2s ease;
  }
  @keyframes tl-flash {
    from {
      background: var(--color-accent-soft);
    }
    to {
      background: transparent;
    }
  }
  .tl-list {
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .tl-item {
    display: grid;
    grid-template-columns: 3.2em 14px 44px 1fr auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: var(--hairline);
  }
  /* Friend rows: hidden until the toggle is on. */
  .tl-item--friend {
    display: none;
  }
  .timeline.show-friends .tl-item--friend {
    display: grid;
  }
  .tl-item__date {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .tl-item__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    justify-self: center;
  }
  .tl-item--friend .tl-item__dot {
    border-color: var(--fdot);
  }
  .tl-item__cover {
    display: block;
  }
  .tl-item--friend .tl-item__cover {
    opacity: 0.92;
  }
  .tl-item__body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .tl-item__title {
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    line-height: var(--leading-snug);
  }
  .tl-item__title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .tl-item__ext {
    color: var(--color-muted);
    font-size: 0.8em;
  }
  .tl-item__author {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .tl-item__who {
    font-weight: var(--weight-medium);
  }
  @media (max-width: 32rem) {
    .tl-month {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
    .tl-month__label {
      position: static;
      padding-top: var(--space-3);
    }
    .tl-item {
      grid-template-columns: 2.8em 10px 36px 1fr;
    }
    .tl-item :global(.stars) {
      display: none;
    }
  }
</style>
