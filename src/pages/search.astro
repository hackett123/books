---
import BaseLayout from "../layouts/BaseLayout.astro";
import Search from "astro-pagefind/components/Search.astro";
---

<BaseLayout title="Search" description="Search the reviews.">
  <section class="measure">
    <p class="eyebrow">Find a book</p>
    <h1>Search</h1>
    <p class="meta">
      Search titles, authors, and the full text of every review.
    </p>

    <div class="search-wrap">
      <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false }} />
    </div>

    <p class="search-note meta">
      Note: search runs on the built site — try it after
      <code>npm run build &amp;&amp; npm run preview</code> (the index isn't
      generated by <code>npm run dev</code>).
    </p>
  </section>
</BaseLayout>

<style>
  .search-wrap {
    margin-top: var(--space-5);
    /* Pagefind UI theming via its CSS variables, mapped to our tokens. */
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-faint);
    --pagefind-ui-tag: var(--color-accent-soft);
    --pagefind-ui-border-radius: var(--radius);
    --pagefind-ui-font: var(--font-sans);
  }
  .search-note {
    margin-top: var(--space-5);
  }
</style>
