---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookCover from "../components/BookCover.astro";
import StarRating from "../components/StarRating.astro";
import { getPublishedReviews } from "../lib/reviews";
import { getShelf } from "../lib/shelf";
import { withBase } from "../lib/url";

// A "shelf of honor": every top-rated book you've read — reviewed or not.
// Reviewed favorites link to the review; rated-but-unreviewed ones link out
// to Goodreads. This matches the 5★ count on /stats.
type Fav = {
  title: string;
  author: string;
  rating: number;
  cover?: string;
  href: string;
  external: boolean;
};

const reviews = await getPublishedReviews();

const reviewedFavs: Fav[] = reviews
  .filter(
    (r) =>
      r.data.rating >= 5 ||
      r.data.shelves.some((s) => s.toLowerCase() === "favorites")
  )
  .map((r) => ({
    title: r.data.title,
    author: r.data.author,
    rating: r.data.rating,
    cover: r.data.cover,
    href: withBase(`/reviews/${r.id}`),
    external: false,
  }));

const shelfFavs: Fav[] = getShelf()
  .filter((b) => b.rating >= 5)
  .map((b) => ({
    title: b.title,
    author: b.author,
    rating: b.rating,
    cover: b.cover,
    href: b.url ?? "#",
    external: true,
  }));

const favorites = [...reviewedFavs, ...shelfFavs].sort((a, b) =>
  a.title.localeCompare(b.title)
);
---

<BaseLayout
  title="Favorites"
  description="The shelf of honor — books that earned the top marks."
>
  <section class="measure">
    <p class="eyebrow">The shelf of honor</p>
    <h1>Favorites</h1>
    <p class="intro__lede">
      The ones that stuck. Five-star reads and the books I keep pressing on
      people.
    </p>
  </section>

  {
    favorites.length === 0 ? (
      <p class="measure" style="color:var(--color-muted)">
        No favorites yet — rate a review 5★ (or shelve it "favorites").
      </p>
    ) : (
      <ul class="gallery">
        {favorites.map((f) => {
          const linkAttrs = f.external
            ? { rel: "nofollow noopener", target: "_blank" }
            : {};
          return (
            <li class="fav">
              <a href={f.href} class="fav__cover" {...linkAttrs}>
                <BookCover
                  cover={f.cover}
                  title={f.title}
                  author={f.author}
                  width={170}
                />
              </a>
              <div class="fav__meta">
                <a href={f.href} class="fav__title" {...linkAttrs}>
                  {f.title}
                  {f.external && <span class="fav__ext" title="Rated, not yet reviewed"> ↗</span>}
                </a>
                <span class="fav__author">{f.author}</span>
                <StarRating rating={f.rating} size="0.9rem" />
              </div>
            </li>
          );
        })}
      </ul>
    )
  }
</BaseLayout>

<style>
  .gallery {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: var(--space-7) var(--space-5);
  }
  .fav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .fav__cover {
    display: block;
    transition: transform var(--transition);
  }
  .fav__cover:hover {
    transform: translateY(-4px) rotate(-0.5deg);
  }
  .fav__meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .fav__title {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    color: var(--color-ink);
    line-height: var(--leading-snug);
  }
  .fav__title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .fav__author {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .fav__ext {
    color: var(--color-muted);
    font-size: 0.8em;
  }
</style>
