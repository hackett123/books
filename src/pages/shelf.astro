---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookCover from "../components/BookCover.astro";
import StarRating from "../components/StarRating.astro";
import { getShelf } from "../lib/shelf";

const books = getShelf();

// Counts per whole-star bucket (rounded, matching the /stats histogram), so we
// only render filter buttons that actually have books behind them.
const starCounts = [5, 4, 3, 2, 1].map((star) => ({
  star,
  count: books.filter((b) => Math.round(b.rating) === star).length,
}));
---

<BaseLayout
  title="The Shelf"
  description="Everything I've read — the full shelf, rated."
>
  <section class="intro measure">
    <p class="eyebrow">Read, rated, unreviewed</p>
    <h1>The Shelf</h1>
    <p class="intro__lede">
      Books I've finished but haven't written up. Stars only — for now.
    </p>
  </section>

  {
    books.length === 0 ? (
      <p class="empty measure">
        The shelf is empty. Run the Goodreads importer to populate it.
      </p>
    ) : (
      <>
        <div class="filter" role="group" aria-label="Filter shelf by rating">
          <a class="filter__btn" href="/shelf" data-filter="all" aria-pressed="true">
            All <span class="filter__n">{books.length}</span>
          </a>
          {starCounts
            .filter((s) => s.count > 0)
            .map((s) => (
              <a
                class="filter__btn"
                href={`/shelf?rating=${s.star}`}
                data-filter={s.star}
                aria-pressed="false"
              >
                {s.star}★ <span class="filter__n">{s.count}</span>
              </a>
            ))}
        </div>

        <ul class="grid">
          {books.map((b) => (
            <li class="grid__item" data-rating={Math.round(b.rating)}>
              {b.url ? (
                <a href={b.url} rel="nofollow noopener" target="_blank">
                  <BookCover cover={b.cover} title={b.title} author={b.author} width={140} />
                </a>
              ) : (
                <BookCover cover={b.cover} title={b.title} author={b.author} width={140} />
              )}
              <div class="grid__meta">
                <span class="grid__title">{b.title}</span>
                <span class="grid__author">{b.author}</span>
                <StarRating rating={b.rating} size="0.85rem" />
              </div>
            </li>
          ))}
        </ul>

        <p class="filter-empty" hidden>No shelf books with that rating.</p>
      </>
    )
  }
</BaseLayout>

<script>
  const items = [...document.querySelectorAll<HTMLElement>(".grid__item")];
  const buttons = [...document.querySelectorAll<HTMLElement>(".filter__btn")];
  const emptyMsg = document.querySelector<HTMLElement>(".filter-empty");

  function apply(value: string | null) {
    const rating = value && value !== "all" ? Number(value) : null;
    let shown = 0;
    for (const li of items) {
      const ok = rating === null || Number(li.dataset.rating) === rating;
      li.hidden = !ok;
      if (ok) shown++;
    }
    const active = rating === null ? "all" : String(rating);
    for (const b of buttons) {
      b.setAttribute("aria-pressed", String((b.dataset.filter || "all") === active));
    }
    if (emptyMsg) emptyMsg.hidden = shown > 0;
    const url = new URL(location.href);
    if (rating === null) url.searchParams.delete("rating");
    else url.searchParams.set("rating", String(rating));
    history.replaceState(null, "", url);
  }

  for (const b of buttons) {
    b.addEventListener("click", (e) => {
      e.preventDefault();
      apply(b.dataset.filter ?? "all");
    });
  }

  apply(new URLSearchParams(location.search).get("rating"));
</script>

<style>
  .intro {
    margin-bottom: var(--space-5);
  }
  .filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .filter__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: var(--text-sm);
    color: var(--color-ink);
    border: var(--hairline);
    border-radius: 999px;
    padding: 0.25em 0.8em;
    transition: all var(--transition);
  }
  .filter__btn:hover {
    text-decoration: none;
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .filter__btn[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-bg);
  }
  .filter__n {
    font-size: 0.8em;
    opacity: 0.75;
    font-variant-numeric: tabular-nums;
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-6) var(--space-5);
  }
  .grid__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .grid__item[hidden] {
    display: none;
  }
  .grid__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .grid__title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
  }
  .grid__author {
    font-size: var(--text-xs);
    color: var(--color-muted);
  }
  .filter-empty {
    color: var(--color-muted);
    margin-top: var(--space-5);
  }
  .empty {
    color: var(--color-muted);
  }
</style>
