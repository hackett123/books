---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewCard from "../../components/ReviewCard.astro";
import Divider from "../../components/Divider.astro";
import { getPublishedReviews, excerpt } from "../../lib/reviews";
import { withBase } from "../../lib/url";

const reviews = await getPublishedReviews();
---

<BaseLayout title="Reviews" description="Book reviews and reading notes.">
  <section class="intro measure">
    <p class="eyebrow">Reading log</p>
    <h1>Notes from the margins.</h1>
    <p class="intro__lede">
      Reviews, reactions, and the occasional underline. What I read and what
      I made of it.
    </p>
  </section>

  <Divider mark="☾" />

  {
    reviews.length === 0 ? (
      <div class="empty measure">
        <p>
          No reviews yet. Run the Goodreads importer to backfill, or add a
          Markdown file to <code>src/content/reviews/</code>.
        </p>
      </div>
    ) : (
      <div class="feed measure">
        {reviews.map((r) => (
          <ReviewCard
            href={withBase(`/reviews/${r.id}`)}
            title={r.data.title}
            author={r.data.author}
            rating={r.data.rating}
            cover={r.data.cover}
            dateRead={r.data.dateRead}
            excerpt={excerpt(r.body)}
          />
        ))}
      </div>
    )
  }
</BaseLayout>

<style>
  .intro {
    margin-bottom: var(--space-6);
  }
  .intro h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-3);
  }
  .intro__lede {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 34rem;
  }
  .feed > :global(article:first-child) {
    border-top: var(--hairline);
  }
  .empty {
    padding: var(--space-6);
    border: var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    color: var(--color-muted);
  }
</style>
