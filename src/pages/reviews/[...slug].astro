---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StarRating from "../../components/StarRating.astro";
import BookCover from "../../components/BookCover.astro";
import { getPublishedReviews, formatDate } from "../../lib/reviews";

export async function getStaticPaths() {
  // Include drafts here so you can preview them by direct URL.
  const { getCollection } = await import("astro:content");
  const reviews = await getCollection("reviews");
  return reviews.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const dateRead = formatDate(data.dateRead);

// Simple prev/next across published reviews.
const published = await getPublishedReviews();
const idx = published.findIndex((r) => r.id === entry.id);
const prev = idx >= 0 ? published[idx + 1] : undefined; // older
const next = idx > 0 ? published[idx - 1] : undefined; // newer
---

<BaseLayout title={data.title} description={`Review of ${data.title} by ${data.author}`}>
  <article>
    <header class="review-head">
      <div class="review-head__cover">
        <BookCover
          cover={data.cover}
          title={data.title}
          author={data.author}
          width={150}
        />
      </div>
      <div class="review-head__meta">
        <p class="eyebrow">Review</p>
        <h1>{data.title}</h1>
        <p class="review-head__author">by {data.author}</p>
        <div class="review-head__rating">
          <StarRating rating={data.rating} size="1.3rem" />
          {dateRead && <span class="meta">· Read {dateRead}</span>}
        </div>
        {
          data.goodreadsUrl && (
            <p class="meta review-head__source">
              <a href={data.goodreadsUrl} rel="nofollow noopener" target="_blank">
                View on Goodreads ↗
              </a>
            </p>
          )
        }
      </div>
    </header>

    {
      data.needsReviewText && (
        <p class="notice">
          ⚠ This review was truncated by Goodreads on import. Paste the full
          text into this file and remove the <code>needsReviewText</code> /
          <code>draft</code> flags.
        </p>
      )
    }

    <div class="prose review-body drop-cap">
      <Content />
    </div>

    {
      data.shelves.length > 0 && (
        <ul class="tags" aria-label="Shelves">
          {data.shelves.map((s) => (
            <li>{s}</li>
          ))}
        </ul>
      )
    }
  </article>

  <nav class="pager measure" aria-label="More reviews">
    {
      prev ? (
        <a class="pager__link" href={`/reviews/${prev.id}`}>
          <span class="meta">← Older</span>
          <span>{prev.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    {
      next && (
        <a class="pager__link pager__link--right" href={`/reviews/${next.id}`}>
          <span class="meta">Newer →</span>
          <span>{next.data.title}</span>
        </a>
      )
    }
  </nav>
</BaseLayout>

<style>
  .review-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-6);
    align-items: start;
    max-width: var(--measure);
    margin-inline: auto;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: var(--hairline);
  }
  .review-head h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
  }
  .review-head__author {
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }
  .review-head__rating {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .review-head__source {
    margin-top: var(--space-3);
  }
  .review-body {
    margin-block: var(--space-5);
  }
  .notice {
    max-width: var(--measure);
    margin-inline: auto;
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: var(--radius);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
  }
  .tags {
    max-width: var(--measure);
    margin: var(--space-6) auto 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .tags li {
    font-size: var(--text-xs);
    color: var(--color-muted);
    border: var(--hairline);
    border-radius: 999px;
    padding: 0.2em 0.7em;
  }
  .pager {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: var(--hairline);
  }
  .pager__link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--color-ink);
    max-width: 45%;
  }
  .pager__link--right {
    text-align: right;
    margin-left: auto;
  }
  .pager__link:hover {
    text-decoration: none;
    color: var(--color-accent);
  }
  @media (max-width: 32rem) {
    .review-head {
      grid-template-columns: 1fr;
    }
  }
</style>
