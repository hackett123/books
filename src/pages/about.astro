---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/url";
---

<BaseLayout title="About">
  <article class="prose measure">
    <p class="eyebrow">About</p>
    <h1>About this site</h1>
    <p>
      This is a reading log — a place to keep my book reviews and the notes I
      scribble in the margins. It started as a backfill of my Goodreads
      reviews and grows from here.
    </p>
    <p>
      I also track what my friends are reading. Their shelves are pulled in from
      Goodreads too, so the <a href={withBase("/friends")}>friends</a> page shows
      their stats and recent reads alongside mine, and the timeline can overlay
      their reading on top of my own.
    </p>
  </article>
</BaseLayout>
