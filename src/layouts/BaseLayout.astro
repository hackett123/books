---
// Self-hosted web fonts (no external request at runtime):
//   Fraunces — a literary, optical-sizing serif for display/headings
//   Inter    — a clean, highly legible sans for body/UI
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "../styles/global.css";
import { getAllTags } from "../lib/tags";
import { withBase, stripBase } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
}

// Only surface the Tags link once reviews actually carry shelves/tags.
const hasTags = (await getAllTags()).length > 0;

const siteName = "Marginalia";
const tagline = "A reading log & book reviews";
const {
  title,
  description = "Book reviews and reading notes.",
} = Astro.props;
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} — ${tagline}`;

const nav = [
  { href: "/", label: "Shelf" },
  { href: "/reviews", label: "Reviews" },
  { href: "/favorites", label: "Favorites" },
  { href: "/timeline", label: "Timeline" },
  { href: "/friends", label: "Friends" },
  { href: "/quotes", label: "Quotes" },
  { href: "/stats", label: "Stats" },
  { href: "/about", label: "About" },
];
const path = stripBase(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={withBase("/rss.xml")}
    />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    {/* Apply the saved/preferred theme before first paint to avoid a flash. */}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const dark =
            stored === "dark" ||
            (stored === null &&
              window.matchMedia("(prefers-color-scheme: dark)").matches);
          if (dark) document.documentElement.dataset.theme = "dark";
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <div class="brand-group">
          <button
            class="theme-toggle"
            id="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            aria-pressed="false"
            title="Toggle dark mode"
          >
            <span class="theme-toggle__moon" aria-hidden="true">☾</span>
            <span class="theme-toggle__sun" aria-hidden="true">☀</span>
          </button>
          <a href={withBase("/")} class="brand">
            <span class="brand__name">{siteName}</span>
          </a>
        </div>
        <button
          class="nav-toggle"
          id="nav-toggle"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="primary-nav"
        />
        <nav class="primary-nav" id="primary-nav" aria-label="Primary">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={withBase(item.href)}
                    aria-current={
                      (item.href === "/" && path === "/") ||
                      (item.href !== "/" && path.startsWith(item.href))
                        ? "page"
                        : undefined
                    }
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a href={withBase("/search")} class="nav-search">
                <span aria-hidden="true">⌕</span>
                <span class="nav-search__label">Search</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>© {new Date().getFullYear()} {siteName}</span>
        <span class="site-footer__links">
          {hasTags && <a href={withBase("/tags")}>Tags</a>}
          <a href={withBase("/stats")}>Stats</a>
          <a href={withBase("/rss.xml")}>RSS</a>
        </span>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: var(--hairline);
        background: color-mix(in srgb, var(--color-bg) 85%, transparent);
        backdrop-filter: saturate(140%) blur(6px);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .site-header__inner {
        position: relative; /* anchor for the mobile dropdown */
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-5);
        padding-block: var(--space-4);
      }
      .brand-group {
        display: inline-flex;
        align-items: baseline;
        gap: 0.45rem;
      }
      .brand {
        display: inline-flex;
        align-items: baseline;
        color: var(--color-ink);
        font-weight: var(--weight-bold);
        font-size: var(--text-lg);
        letter-spacing: -0.01em;
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand__name {
        font-family: var(--font-display);
      }

      /* The crescent moon doubles as the dark-mode toggle; it swaps to a sun
         once dark is active. */
      .theme-toggle {
        display: inline-flex;
        align-items: baseline;
        padding: 0;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-accent);
        font-family: var(--font-serif);
        font-size: calc(var(--text-lg) * 1.15);
        line-height: 1;
        transform: translateY(0.02em);
        transition: color var(--transition), transform var(--transition);
      }
      .theme-toggle:hover {
        transform: translateY(0.02em) rotate(-12deg);
      }
      .theme-toggle:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 3px;
        border-radius: var(--radius);
      }
      .theme-toggle__sun {
        display: none;
      }
      :root[data-theme="dark"] .theme-toggle__moon {
        display: none;
      }
      :root[data-theme="dark"] .theme-toggle__sun {
        display: inline;
        color: var(--color-star);
      }
      nav ul {
        list-style: none;
        display: flex;
        gap: var(--space-5);
        margin: 0;
        padding: 0;
      }
      nav a {
        color: var(--color-muted);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        letter-spacing: 0.01em;
      }
      nav a[aria-current="page"] {
        color: var(--color-ink);
        background-image: var(--ink-underline);
        background-repeat: no-repeat;
        background-position: 0 100%;
        background-size: 100% 0.5em;
        padding-bottom: 0.15em;
      }
      .nav-search {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        font-size: 1.15rem;
        line-height: 1;
      }
      .nav-search__label {
        display: none; /* desktop shows the glyph only */
      }

      /* Hamburger button — hidden on desktop, shown on mobile. */
      .nav-toggle {
        display: none;
        width: 2.4rem;
        height: 2.4rem;
        align-items: center;
        justify-content: center;
        padding: 0;
        background: none;
        border: none;
        color: var(--color-ink);
        font-size: 1.45rem;
        line-height: 1;
        cursor: pointer;
      }
      .nav-toggle::before {
        content: "☰";
      }
      .site-header.nav-open .nav-toggle::before {
        content: "✕";
        font-size: 1.25rem;
      }

      /* Mobile: collapse the nav into a dropdown panel under the header. */
      @media (max-width: 56rem) {
        .nav-toggle {
          display: inline-flex;
        }
        .primary-nav {
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          display: none;
          background: var(--color-bg);
          border-bottom: var(--hairline);
          box-shadow: var(--shadow-md);
        }
        .site-header.nav-open .primary-nav {
          display: block;
        }
        .primary-nav ul {
          flex-direction: column;
          gap: 0;
          padding: var(--space-2) var(--space-5) var(--space-4);
        }
        .primary-nav li {
          border-bottom: var(--hairline);
        }
        .primary-nav li:last-child {
          border-bottom: none;
        }
        .primary-nav a {
          display: block;
          padding: var(--space-3) 0;
          font-size: var(--text-base);
        }
        .primary-nav a[aria-current="page"] {
          background: none;
          padding-bottom: var(--space-3);
          color: var(--color-ink);
          font-weight: var(--weight-bold);
        }
        .nav-search {
          font-size: var(--text-base);
          gap: 0.5em;
        }
        .nav-search__label {
          display: inline;
        }
      }
      main.container {
        padding-block: var(--space-7) var(--space-8);
        min-height: 60vh;
      }
      .site-footer {
        border-top: var(--hairline);
        margin-top: var(--space-8);
      }
      .site-footer__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-block: var(--space-5);
        color: var(--color-muted);
        font-size: var(--text-sm);
      }
      .site-footer__links {
        display: flex;
        gap: var(--space-4);
      }
    </style>

    <script>
      // Dark-mode toggle — the moon in the header. The pre-paint inline script
      // in <head> has already applied the stored/preferred theme; here we just
      // flip it and persist the explicit choice.
      const themeToggle = document.getElementById("theme-toggle");
      if (themeToggle) {
        const root = document.documentElement;
        const sync = () =>
          themeToggle.setAttribute(
            "aria-pressed",
            String(root.dataset.theme === "dark")
          );
        sync();
        themeToggle.addEventListener("click", () => {
          const dark = root.dataset.theme === "dark";
          if (dark) delete root.dataset.theme;
          else root.dataset.theme = "dark";
          try {
            localStorage.setItem("theme", dark ? "light" : "dark");
          } catch (e) {}
          sync();
        });
      }

      const toggle = document.getElementById("nav-toggle");
      const header = toggle?.closest(".site-header") as HTMLElement | null;
      if (toggle && header) {
        const setOpen = (open: boolean) => {
          header.classList.toggle("nav-open", open);
          toggle.setAttribute("aria-expanded", String(open));
        };
        toggle.addEventListener("click", () =>
          setOpen(!header.classList.contains("nav-open"))
        );
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") setOpen(false);
        });
        document.addEventListener("click", (e) => {
          if (!header.contains(e.target as Node)) setOpen(false);
        });
      }
    </script>
  </body>
</html>
