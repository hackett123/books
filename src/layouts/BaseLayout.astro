---
import "../styles/global.css";
import { getAllTags } from "../lib/tags";

interface Props {
  title?: string;
  description?: string;
}

// Only surface the Tags link once reviews actually carry shelves/tags.
const hasTags = (await getAllTags()).length > 0;

const siteName = "Marginalia";
const tagline = "A reading log & book reviews";
const {
  title,
  description = "Book reviews and reading notes.",
} = Astro.props;
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} — ${tagline}`;

const nav = [
  { href: "/", label: "Reviews" },
  { href: "/favorites", label: "Favorites" },
  { href: "/shelf", label: "Shelf" },
  { href: "/quotes", label: "Quotes" },
  { href: "/stats", label: "Stats" },
  { href: "/about", label: "About" },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href="/rss.xml"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="brand">
          <span class="brand__mark" aria-hidden="true">☾</span>
          <span class="brand__name">{siteName}</span>
        </a>
        <nav aria-label="Primary">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={
                      (item.href === "/" && path === "/") ||
                      (item.href !== "/" && path.startsWith(item.href))
                        ? "page"
                        : undefined
                    }
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a href="/search" class="nav-search" aria-label="Search">⌕</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span>© {new Date().getFullYear()} {siteName}</span>
        <span class="site-footer__links">
          {hasTags && <a href="/tags">Tags</a>}
          <a href="/stats">Stats</a>
          <a href="/rss.xml">RSS</a>
        </span>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: var(--hairline);
        background: color-mix(in srgb, var(--color-bg) 85%, transparent);
        backdrop-filter: saturate(140%) blur(6px);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-5);
        padding-block: var(--space-4);
      }
      .brand {
        display: inline-flex;
        align-items: baseline;
        gap: 0.45rem;
        color: var(--color-ink);
        font-weight: var(--weight-bold);
        font-size: var(--text-lg);
        letter-spacing: -0.01em;
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand__name {
        font-family: var(--font-display);
      }
      .brand__mark {
        color: var(--color-accent);
        font-family: var(--font-serif);
        font-size: 1.15em;
        transform: translateY(0.02em);
      }
      nav ul {
        list-style: none;
        display: flex;
        gap: var(--space-5);
        margin: 0;
        padding: 0;
      }
      nav a {
        color: var(--color-muted);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        letter-spacing: 0.01em;
      }
      nav a[aria-current="page"] {
        color: var(--color-ink);
        background-image: var(--ink-underline);
        background-repeat: no-repeat;
        background-position: 0 100%;
        background-size: 100% 0.5em;
        padding-bottom: 0.15em;
      }
      .nav-search {
        font-size: 1.15rem;
        line-height: 1;
      }
      main.container {
        padding-block: var(--space-7) var(--space-8);
        min-height: 60vh;
      }
      .site-footer {
        border-top: var(--hairline);
        margin-top: var(--space-8);
      }
      .site-footer__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-block: var(--space-5);
        color: var(--color-muted);
        font-size: var(--text-sm);
      }
      .site-footer__links {
        display: flex;
        gap: var(--space-4);
      }
    </style>
  </body>
</html>
